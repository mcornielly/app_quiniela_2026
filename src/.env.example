APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
VITE_APP_URL="${APP_URL}"

REVERB_APP_ID=app_quiniela_2026
REVERB_APP_KEY=base64:local-key
REVERB_APP_SECRET=local-secret
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Seeder asset resolution (Railway-friendly defaults)
SEEDER_ALLOW_STORAGE_FALLBACK=false
SHIELD_IMPORT_LEGACY_ZIP=false

# API-FOOTBALL (API-SPORTS)
API_FOOTBALL_KEY=
API_FOOTBALL_URL=https://v3.football.api-sports.io
API_FOOTBALL_TIMEOUT=15
API_FOOTBALL_RETRY_TIMES=2
API_FOOTBALL_RETRY_SLEEP_MS=250
API_FOOTBALL_CACHE_COUNTRIES=86400
API_FOOTBALL_CACHE_VENUES=86400
API_FOOTBALL_CACHE_TEAMS=43200
API_FOOTBALL_CACHE_FIXTURES=1800
API_FOOTBALL_CACHE_LIVE=15
API_FOOTBALL_CACHE_EVENTS=60
API_FOOTBALL_CACHE_LINEUPS=600
API_FOOTBALL_CACHE_STATISTICS=300
API_FOOTBALL_CACHE_LEAGUES=86400
API_FOOTBALL_CACHE_STANDINGS=3600
API_FOOTBALL_WORLD_CUP_LEAGUE=1
API_FOOTBALL_WORLD_CUP_SEASON=2026

# Admin bootstrap user (required by CreateAdminUserSeeder)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=
