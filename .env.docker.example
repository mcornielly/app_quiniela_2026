APP_NAME=Quiniela
APP_ENV=local
APP_KEY=base64:5R7fO39j8vC2yF2Yx9g9fQwT8xv1I8Y8v7f2F6f9lG0=
APP_DEBUG=true
APP_URL=http://astrocopa.app.test

LOG_CHANNEL=stack
LOG_LEVEL=debug

APP_RUNTIME_ROLE=web
PORT=8080
ENABLE_VITE_DEV_SERVER=true
VITE_PORT=5173
RUN_MIGRATIONS=true

DB_CONNECTION=sqlite
DB_DATABASE=/var/www/html/database/database.sqlite
# If you want Docker MySQL, uncomment and adjust:
# DB_CONNECTION=mysql
# DB_HOST=mysql
# DB_PORT=3306
# DB_DATABASE=quiniela
# DB_USERNAME=quiniela
# DB_PASSWORD=quiniela123

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=database

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

BROADCAST_CONNECTION=reverb
REVERB_APP_ID=app_quiniela_2026
REVERB_APP_KEY=base64:local-key
REVERB_APP_SECRET=local-secret
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

VITE_APP_URL=${APP_URL}
VITE_REVERB_APP_KEY=${REVERB_APP_KEY}
VITE_REVERB_HOST=astrocopa.app.test
VITE_REVERB_PORT=8081
VITE_REVERB_SCHEME=http

# MySQL container variables (only used when --profile mysql)
MYSQL_DATABASE=quiniela
MYSQL_USER=quiniela
MYSQL_PASSWORD=quiniela123
MYSQL_ROOT_PASSWORD=root


VITE_HMR_HOST=astrocopa.app.test
VITE_DEV_SERVER_ORIGIN=http://astrocopa.app.test:5173

# API-SPORTS Widgets (frontend)
VITE_API_SPORTS_WIDGET_KEY=${API_FOOTBALL_KEY}
VITE_API_SPORTS_WIDGET_SPORT=football
VITE_API_SPORTS_WIDGET_LANG=es
VITE_API_SPORTS_WIDGET_SCRIPT_URL=https://widgets.api-sports.io/2.0.3/widgets.js

# API-FOOTBALL (API-SPORTS)
API_FOOTBALL_KEY=
API_FOOTBALL_URL=https://v3.football.api-sports.io
